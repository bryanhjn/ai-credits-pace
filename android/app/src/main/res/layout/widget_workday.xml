<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="14dp"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:background="@drawable/widget_background">

    <!-- 工作日标题行 -->
    <TextView
        android:id="@+id/workday_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="工作日(0.0%)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1F2937" />

    <!-- 工作日进度条（加粗至 14dp，充分利用纵向空间） -->
    <ProgressBar
        android:id="@+id/workday_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#6366F1"
        android:progressBackgroundTint="#E5E7EB" />

    <!-- Credits 标题行 -->
    <TextView
        android:id="@+id/credits_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Credits(0.0%)"
        android:textSize="13sp"
        android:textStyle="bold"
        android:textColor="#1F2937" />

    <!-- Credits 进度条（加粗至 14dp） -->
    <ProgressBar
        android:id="@+id/credits_bar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="14dp"
        android:layout_marginTop="4dp"
        android:max="100"
        android:progress="0"
        android:progressTint="#10B981"
        android:progressBackgroundTint="#E5E7EB" />

</LinearLayout>
